# syntax=docker/dockerfile:1.7

# ---------- Build stage: render Quarto site ----------
FROM ghcr.io/quarto-dev/quarto:1.7.32 AS build

WORKDIR /src

# Install runtime deps for diagrams (mermaid via chromium for static export, optional)
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     chromium fonts-liberation && rm -rf /var/lib/apt/lists/*

# Copy project sources
COPY . .

# Render site to _site/
RUN quarto render --output-dir _site

# ---------- Runtime stage: serve via nginx ----------
FROM nginx:1.27-alpine AS runtime

# Copy nginx config
COPY container/nginx.conf /etc/nginx/conf.d/default.conf

# Copy rendered site
COPY --from=build /src/_site /usr/share/nginx/html

# Non-root user (nginx image runs as root by default for port 80)
# ZAD uses port 8080 — adjust if needed
EXPOSE 8080

# Healthcheck endpoint
HEALTHCHECK --interval=30s --timeout=3s CMD wget -q --spider http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
