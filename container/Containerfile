# syntax=docker/dockerfile:1.7

# ---------- Build stage: render Quarto site ----------
FROM ghcr.io/quarto-dev/quarto:1.7.32 AS build

WORKDIR /src

# Install runtime deps for diagrams (mermaid via chromium for static export, optional)
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     chromium fonts-liberation && rm -rf /var/lib/apt/lists/*

# Copy project sources
COPY . .

# Render site to _site/ (HTML only — PDF/Typst vereist netwerk-toegang voor packages)
RUN quarto render --to html --output-dir _site

# Kopieer pre-gerenderde PDFs naast HTML (gerendered lokaal, gecommit in assets/pdf/)
RUN cp -r /src/assets/pdf/. /src/_site/ 2>/dev/null || true

# ---------- Runtime stage: serve via nginx (non-root) ----------
FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime

# Copy nginx config (writable as nginx user)
COPY --chown=nginx:nginx container/nginx.conf /etc/nginx/conf.d/default.conf

# Copy rendered site
COPY --chown=nginx:nginx --from=build /src/_site /usr/share/nginx/html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s CMD wget -q --spider http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
